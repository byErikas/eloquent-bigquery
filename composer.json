{
    "name": "byerikas/eloquent-bigquery",
    "description": "Simple BigQuery wrapper in the style of Laravel's Eloquent",
    "keywords": [
        "bigquery",
        "eloquent",
        "laravel"
    ],
    "version": "1.0.3",
    "license": "MIT",
    "require": {
        "laravel/framework": "^10.0|^11.0|^12.0",
        "google/cloud-bigquery": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "ByErikas\\EloquentBigQuery\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "byErikas",
            "email": "erikasbystautas1@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}